# Email notification settings (optional - browser notifications work without this)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFICATION_EMAIL=your-email@gmail.com

# Shared secret required on every /api request (x-api-key header or ?key= query param).
# Leave unset for local dev; set this before exposing the server publicly.
API_KEY=

# Server settings
PORT=3000

# Check interval in minutes (how often to check prices)
CHECK_INTERVAL_MINUTES=30

# Chrome path (auto-detected if not set)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
